            self._filter_active_dialogs.append(dlg)
        try:
            dlg.destroyed.connect(lambda obj=None, d=dlg: self._untrack_child_dialog(d))
            dlg.finished.connect(lambda result, d=dlg: self._untrack_child_dialog(d))
        except Exception:
            pass

