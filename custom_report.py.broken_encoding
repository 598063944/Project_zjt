})


def _normalize_expr(expr: str) -> str:
    """灏嗕腑鏂囨爣鐐硅浆涓鸿嫳鏂囨爣鐐癸紝鍘婚櫎棣栧熬绛夊彿銆?""
    expr = expr.strip()
    if expr.startswith("="):
        expr = expr[1:]
    return expr.translate(_CJK_PUNCT_MAP)


