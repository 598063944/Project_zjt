def _light_msgbox(parent, icon, title, text):
    """鏄剧ず娴呰壊鑳屾櫙鐨勬秷鎭脊绐楋紙閬垮厤绯荤粺娣辫壊涓婚瀵艰嚧榛戝簳锛夈€?""
