        """娓呴櫎鎵€鏈夌瓫閫夎"""
        for row in self._filter_rows[:]:
            row["widget"].deleteLater()
        self._filter_rows.clear()
        self._interact_grid.addWidget(self._filter_add_btn, 2, 0, 1, 4)

