                    ok = (rv != v_num) if is_numeric else (rv_str != value)
                elif op in ('澶т簬', '灏忎簬', '澶т簬绛変簬', '灏忎簬绛変簬'):
                    if not is_numeric or not isinstance(rv, (int, float)):
                        continue
                    ok = {'澶т簬': rv > v_num, '灏忎簬': rv < v_num,
                          '澶т簬绛変簬': rv >= v_num, '灏忎簬绛変簬': rv <= v_num}[op]
                else:
                    ok = False
                if ok:
                    filtered.append(r)
            result = filtered
    return result


