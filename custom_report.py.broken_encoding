    def _on_rename_folder(self, old_path: str):
        """閲嶅懡鍚嶆枃浠跺す"""
        if not old_path or old_path == "__root__":
            return
        current_name = old_path.split("/")[-1]
        new_name, ok = _light_input(self, "閲嶅懡鍚嶆枃浠跺す", "璇疯緭鍏ユ柊鍚嶇О:", text=current_name)
