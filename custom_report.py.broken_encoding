                return
            dashboard = result['dashboard']
            self._repo.save(dashboard)
            self.refresh()
            print(f"[BI 鎶ヨ〃] 宸茬敓鎴愪华琛ㄧ洏銆寋dashboard.name}銆?{len(dashboard.charts)} 涓浘琛?")
            print("[BI 鎶ヨ〃] 馃挕 鎻愮ず: 姣忎釜鍥捐〃闇€鎵嬪姩閫夋嫨鏁版嵁婧愶紙瀛楁鏄犲皠宸茶嚜鍔ㄥ～鍏咃級")
            # 鎵撳紑浠〃鐩樼紪杈?
            self.editRequested.emit(dashboard.id)
        except Exception as e:
            print(f"[BI 鎶ヨ〃] PBIX/PBIT 瀵煎叆澶辫触: {e}")

