        """鐐瑰嚮琛ㄥご澶嶉€夋锛屽叏閫?鍙栨秷鍏ㄩ€夊綋鍓嶉〉锛堜笌鏂囦欢鐢熸垚/璁㈠崟杞悎鍚屼繚鎸佷竴鑷达級"""
        if not hasattr(self, '_current_page_report_ids'):
            return
        if checked:
            self._checked_ids.update(self._current_page_report_ids)
        else:
            for rid in self._current_page_report_ids:
                self._checked_ids.discard(rid)
        self._is_updating_checkboxes = True
        try:
            for row in range(self._table.rowCount()):
                w = self._table.cellWidget(row, 0)
                if w is not None:
                    from common import TableRowCheckBox
                    cb = w.findChild(TableRowCheckBox)
                    if cb is not None:
                        cb.blockSignals(True)
                        cb.setChecked(checked)
                        cb.blockSignals(False)
        finally:
            self._is_updating_checkboxes = False
        self._table.viewport().update()
        self._update_header_checkbox_state()

    def _update_header_checkbox_state(self):
        """鏇存柊琛ㄥご澶嶉€夋鐘舵€侊紙鍏ㄩ€?閮ㄥ垎閫?鏈€夛級"""
        if not hasattr(self, '_table_header') or not hasattr(self, '_current_page_report_ids'):
            return
        if not self._current_page_report_ids:
            self._table_header.set_check_state(Qt.CheckState.Unchecked)
            return
        checked_count = sum(1 for rid in self._current_page_report_ids if rid in self._checked_ids)
        if checked_count == 0:
            state = Qt.CheckState.Unchecked
        elif checked_count == len(self._current_page_report_ids):
            state = Qt.CheckState.Checked
        else:
            state = Qt.CheckState.PartiallyChecked
        self._table_header.set_check_state(state)

    def _on_batch_refresh_data(self):
        """鎵归噺鍒锋柊閫変腑鐨勬姤琛ㄦ暟鎹?""
        from PyQt6.QtWidgets import QMessageBox

        ids = self._get_selected_report_ids()
        if not ids:
            _light_msgbox(self, QMessageBox.Icon.Information, "鎻愮ず", "璇峰厛鍕鹃€夎鏇存柊鏁版嵁鐨勬姤琛ㄣ€?)
            return

        # 璁板綍姝ｅ湪鍒锋柊鐨勬姤琛ㄥ悕绉?
        id_set = set(ids)
        self._refresh_report_names = [rpt.name for rpt in self._all_reports if rpt.id in id_set]

        # 鍒濆鍖栬繘搴﹁拷韪?
        self._refresh_total = len(ids)
        self._report_progress.clear()
        for rid in ids:
            self._report_progress[rid] = 0
        self._update_data_btn.setEnabled(False)

        # 鍒涘缓骞跺惎鍔ㄦ壒閲忓埛鏂扮嚎绋?
        self._batch_thread = BatchRefreshThread(
            self._mysql_config, self._repo, ids,
            app_config=self._app_config,
        )
        self._batch_thread.report_starting.connect(self._on_refresh_report_starting)
        self._batch_thread.report_progress.connect(self._on_refresh_report_progress)
        self._batch_thread.report_done.connect(self._on_refresh_report_done)
        self._batch_thread.all_done.connect(self._on_refresh_all_done)

        # 鏄剧ず杩涘害闈㈡澘
        self._progress_panel.show()
        self._progress_bar.setValue(0)
        self._progress_label.setText("姝ｅ湪鍒锋柊 (0/" + str(self._refresh_total) + ")")
        self._progress_detail.setText("鍑嗗涓?..")
        self._cancel_btn.setEnabled(True)

        self._batch_thread.start()

    def _on_refresh_cancelled(self):
        """鍙栨秷鎵归噺鍒锋柊"""
        if self._batch_thread and self._batch_thread.isRunning():
            self._cancel_btn.setEnabled(False)
            self._cancel_btn.setText("姝ｅ湪鍙栨秷...")
            self._batch_thread.cancel()

    def _find_row_for_report(self, report_id):
        """鍦ㄨ〃鏍间腑鏌ユ壘鎸囧畾鎶ヨ〃鐨勮绱㈠紩锛堝綋鍓嶉〉鍐咃級锛屾湭鎵惧埌杩斿洖 -1"""
        for row in range(self._table.rowCount()):
            name_item = self._table.item(row, 1)
            if name_item and name_item.data(Qt.ItemDataRole.UserRole) == report_id:
                return row
        return -1

    def _update_row_status(self, report_id, status_text):
        """鏇存柊鎸囧畾鎶ヨ〃琛岀殑鐘舵€佸垪锛坈ol 7锛?""
        row = self._find_row_for_report(report_id)
        if row >= 0:
            status_item = self._table.item(row, 7)
            if status_item:
                status_item.setText(status_text)

    def _update_row_record_count(self, report_id, count):
        """鏇存柊鎸囧畾鎶ヨ〃琛岀殑缁撴灉璁板綍鏁板垪锛坈ol 5锛?""
        row = self._find_row_for_report(report_id)
        if row >= 0:
            self._table.setItem(row, 5, QTableWidgetItem(str(count)))

    def _on_refresh_report_starting(self, report_id, name):
        """鍗曚釜鎶ヨ〃鍒锋柊寮€濮?""
        self._refreshing_ids.add(report_id)
        self._update_row_status(report_id, " 绛夊緟涓?..")
        self._checked_ids.discard(report_id)
        # 绂佺敤璇ヨ澶嶉€夋锛堢敤cellWidget鎿嶄綔QCheckBox锛?
        row = self._find_row_for_report(report_id)
        if row >= 0:
            w = self._table.cellWidget(row, 0)
            if w is not None:
                from common import TableRowCheckBox
                cb = w.findChild(TableRowCheckBox)
                if cb is not None:
                    cb.setChecked(True)
                    cb.setEnabled(False)

    def _on_refresh_report_progress(self, report_id, phase, message):
        """鍗曚釜鎶ヨ〃杩涘害鏇存柊"""
        phase_map = {"sync": "鍚屾CRM", "join": "鎷艰〃", "done": "瀹屾垚"}
        phase_label = phase_map.get(phase, phase)
        self._update_row_status(report_id, " " + phase_label)

        # 鏇存柊鎬讳綋杩涘害鏉?
        if self._refresh_total > 0:
            done_count = sum(1 for v in self._report_progress.values() if v >= 100)
            pct = int(done_count * 100 / self._refresh_total)
            self._progress_bar.setValue(pct)
            self._progress_label.setText("姝ｅ湪鍒锋柊 (" + str(done_count) + "/" + str(self._refresh_total) + ")")

    def _on_refresh_report_done(self, report_id, result):
        """鍗曚釜鎶ヨ〃鍒锋柊瀹屾垚"""
        self._report_progress[report_id] = 100
        self._refreshing_ids.discard(report_id)
        self._checked_ids.discard(report_id)

        if result.get("success"):
            self._update_row_status(report_id, " 宸插畬鎴?)
            self._update_row_record_count(report_id, result.get("row_count", 0))
        else:
            self._update_row_status(report_id, " 澶辫触")

        # 鎭㈠澶嶉€夋
        row = self._find_row_for_report(report_id)
        if row >= 0:
            w = self._table.cellWidget(row, 0)
            if w is not None:
                from common import TableRowCheckBox
                cb = w.findChild(TableRowCheckBox)
                if cb is not None:
                    cb.setChecked(False)
                    cb.setEnabled(True)

    def _on_refresh_all_done(self, success, fail, errors):
        """鍏ㄩ儴鍒锋柊瀹屾垚锛屽彇娑堝脊绐楋紝缁撴灉鎵撳嵃鍒拌繍琛岀獥鍙?""
        self._progress_panel.hide()
        self._cancel_btn.setText("鍙栨秷")
        self._update_data_btn.setEnabled(True)
        self._refreshing_ids.clear()
        self._report_progress.clear()
        self._checked_ids.clear()

        # 鏋勫缓閿欒闆嗗悎锛堝悕绉?-> 閿欒淇℃伅锛?
        error_map = dict(errors)

        # 杈撳嚭姣忎釜鎶ヨ〃鐨勫埛鏂扮粨鏋?
        for name in self._refresh_report_names:
            if name in error_map:
                print(f"澶辫触锛歿name} - {error_map[name]}")
            else:
                print(f"鎴愬姛锛歿name}")

        self._refresh_report_names.clear()

        # 鍒锋柊鍒楄〃鏄剧ず鏈€鏂版暟鎹?
        self.refresh()


