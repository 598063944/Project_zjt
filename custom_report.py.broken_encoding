            return

        dlg = DatePartPickerDialog(available_fields=available_fields, parent=self)
        if dlg.exec() == QDialog.DialogCode.Accepted:
            # Get the base field's display name for the formula
            _display_map = dict((fn, dn) for dn, fn in dlg.available_fields)
            _field_dn = _display_map.get(dlg.source_field_name, dlg.source_field_name)

            if hasattr(self, "custom_report_editor_page") and self.custom_report_editor_page:
                editor = self.custom_report_editor_page
                if hasattr(editor, "_report") and editor._report:
                    from custom_report import FieldColumn
                    _FORMULA_TEMPLATES = {
                        'year': '=YEAR({field})',
                        'month': '=MONTH({field})',
                        'week': '=WEEKNUM({field},2)',
                        'quarter': '=QUARTER({field})',
                    }
                    for unit_info in dlg.selected_units:
                        unit = unit_info['unit']
                        display_name = unit_info['display_name']
                        col = FieldColumn(
                            display_name=display_name,
                            source_object_api=main_api,
                            source_field='',
                            visible=True,
                            computation_type='formula',
                            formula_expression=_FORMULA_TEMPLATES.get(
                                unit,
                                '=' + unit.upper() + '({field})'
                            ).format(field=_field_dn),
                        )
                        editor._report.columns.append(col)

            self._save_custom_report_builder_state()
            self._update_custom_report_filter_summary()
            self.on_custom_report_manual_refresh()

