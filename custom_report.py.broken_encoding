def safe_value_by_format(val, field_format: str = "text"):
    """鏍规嵁瀛楁鏍煎紡灏嗗€煎畨鍏ㄨ浆涓哄搴旂被鍨嬶紝鐢ㄤ簬鍐欏叆 MySQL銆?

