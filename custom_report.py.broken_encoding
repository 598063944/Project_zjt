def _mysql_type_to_generic(mysql_type: str) -> str:
    """灏?MySQL 鏁版嵁绫诲瀷鏄犲皠涓洪€氱敤绫诲瀷"""
    t = (mysql_type or '').lower()
    if any(x in t for x in ('int', 'decimal', 'float', 'double', 'numeric')):
