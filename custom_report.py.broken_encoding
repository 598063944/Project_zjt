        # 鏋勫缓鏂拌矾寰?
        parts = old_path.split("/")
        parts[-1] = new_name.strip()
        new_path = "/".join(parts)

        count = self._repo.rename_folder(old_path, new_path)
        if count >= 0:
            self.refresh()
