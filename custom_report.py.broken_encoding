import logging
import sys


class UILogHandler(logging.Handler):
    """灏嗘棩蹇楀悓鏃惰緭鍑哄埌涓荤▼搴忚繍琛屾椂绐楀彛"""

    def emit(self, record: logging.LogRecord):
        try:
            msg = self.format(record)
            main_mod = sys.modules.get('__main__')
            if main_mod:
                mf = getattr(main_mod, 'MainFrame', None)
                if mf and hasattr(mf, 'instance') and mf.instance:
                    mf.instance.append_output(msg)
                    return
        except Exception:
            pass
        # 鍥為€€锛氭墦鍗板埌 stdout
        print(self.format(record))


def setup_ui_logging():
    """涓烘墍鏈?logger 娣诲姞 UI 鏃ュ織澶勭悊鍣紙杈撳嚭鍒颁富绋嬪簭杩愯鏃剁獥鍙ｏ級"""
    # 闃叉鍦?MainFrame 鍒涘缓涔嬪墠娣诲姞 handler 瀵艰嚧閫掑綊
    import sys as _sys2
    _main = _sys2.modules.get('__main__')
    if not (_main and getattr(_main, 'MainFrame', None) and getattr(_main.MainFrame, 'instance', None)):
        return

    ui_handler = UILogHandler()
    ui_handler.setLevel(logging.INFO)
    ui_handler.addFilter(ImportantOperationLogFilter())
    ui_handler.setFormatter(logging.Formatter('[%(name)s] %(levelname)s - %(message)s'))

    # 閬垮厤閲嶅娣诲姞
    existing = [h for h in logging.root.handlers if isinstance(h, UILogHandler)]
    if existing:
        return

    # 娣诲姞鍒?root logger 鈫?鎹曡幏鎵€鏈夋ā鍧楃殑鏃ュ織
    logging.root.addHandler(ui_handler)
    logging.root.setLevel(logging.INFO)

    # 鍚屾椂娣诲姞鍒?custom_report logger
    cr_logger = logging.getLogger('custom_report')
    cr_logger.addHandler(ui_handler)
    cr_logger.setLevel(logging.INFO)




