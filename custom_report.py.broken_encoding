    def _update_filter_fields(self):
        """鏇存柊绛涢€夋爮瀛楁 + 鎼滅储瀛楁涓嬫媺妗?""
        if not self._preview:
            return
        columns = self._preview.get_result_columns()
        if not columns:
            # 鍥為€€锛氫粠鎶ヨ〃瀹氫箟涓彁鍙栧垪鏄剧ず鍚嶏紙鏁版嵁灏氭湭鍒锋柊鍒?MySQL 鏃讹級
            if self._report_def and hasattr(self._report_def, 'columns'):
                columns = []
                for col in self._report_def.columns:
                    if hasattr(col, 'display_name'):
                        dn = col.display_name
                    elif isinstance(col, dict):
                        dn = col.get('display_name', '')
                    else:
                        dn = ''
                    if dn:
                        columns.append(dn)
            if not columns:
                return
        # 鏇存柊绛涢€夋爮瀛楁
        date_kw = ('鏃堕棿', '鏃ユ湡', '鍒涘缓', '淇敼', '鎻愪氦', 'date', 'time')
        field_list = []
        for col in columns:
            is_date = any(kw in col.lower() for kw in date_kw)
            field_list.append((col, col, is_date))
        self._filter_bar.set_available_fields(field_list)

    def _on_search(self):
        """鎼滅储妗嗗洖杞?""
        text = self._search_input.text().strip()
        self._preview.set_search_columns(None)
        self._preview.set_search_text(text)

