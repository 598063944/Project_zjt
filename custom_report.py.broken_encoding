        self._current_page = 1
        self._populate()

    def _prev_page(self):
        if self._current_page > 1:
            self._current_page -= 1
            self._populate()

    def _next_page(self):
        total = len(self._all_reports)
        page_count = max(1, (total + self._page_size - 1) // self._page_size)
        if self._current_page < page_count:
            self._current_page += 1
            self._populate()

