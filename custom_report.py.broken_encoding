def _large(arr, k):
    """LARGE 鈫?杩斿洖绗?k 涓渶澶у€笺€?""
    arr = pd.to_numeric(arr, errors='coerce').values
    k = int(k)
    # 杩斿洖鏍囬噺
    sorted_arr = np.sort(arr[~np.isnan(arr)])
    if k <= 0 or k > len(sorted_arr):
        return np.nan
    return sorted_arr[-k]


def _small(arr, k):
    """SMALL 鈫?杩斿洖绗?k 涓渶灏忓€笺€?""
    arr = pd.to_numeric(arr, errors='coerce').values
    k = int(k)
    sorted_arr = np.sort(arr[~np.isnan(arr)])
    if k <= 0 or k > len(sorted_arr):
        return np.nan
    return sorted_arr[k - 1]


def _rank(value, ref, order=0):
    """RANK 鈫?杩斿洖鏁板€煎湪鏁扮粍涓殑鎺掑悕銆俹rder: 0=闄嶅簭锛堥粯璁わ級锛岄潪0=鍗囧簭銆?""
    val = pd.to_numeric(value, errors='coerce')
    arr = pd.to_numeric(ref, errors='coerce').values
    # 瀵规瘡涓€琛岃绠楁帓鍚?
    if isinstance(val, pd.Series):
        result = []
        for v in val:
            if pd.isna(v):
                result.append(np.nan)
            else:
                clean = arr[~np.isnan(arr)]
                if order == 0:
                    result.append((clean > v).sum() + 1)
                else:
                    result.append((clean < v).sum() + 1)
        return pd.Series(result, index=val.index)
    else:
        clean = arr[~np.isnan(arr)]
        if order == 0:
            return (clean > val).sum() + 1
        else:
            return (clean < val).sum() + 1


def _mode(*args):
    """MODE 鈫?杩斿洖鍑虹幇鏈€棰戠箒鐨勫€笺€?""
    arr = np.concatenate([a.astype(str).values if isinstance(a, pd.Series) else [str(a)]
                          for a in args])
    if len(arr) == 0:
        return ''
    unique, counts = np.unique(arr, return_counts=True)
    return unique[np.argmax(counts)]


