    def keyReleaseEvent(self, event):
        if event.key() == Qt.Key.Key_Space:
            self._space_held = False
            if not self._panning:
                self.setCursor(Qt.CursorShape.ArrowCursor)
        super().keyReleaseEvent(event)

    # ==================== 缁樺埗瑕嗙洊灞?====================

    def drawForeground(self, painter: QPainter, rect: QRectF):
        """缁樺埗涓存椂杩炵嚎"""
        super().drawForeground(painter, rect)
        if self._connecting and self._connect_temp_line:
            painter.setRenderHint(QPainter.RenderHint.Antialiasing)
            pen = QPen(QColor("#FF8C00"), 2, Qt.PenStyle.DashLine)
            painter.setPen(pen)
            painter.drawLine(self._connect_temp_line)

    def drawBackground(self, painter: QPainter, rect: QRectF):
        """缁樺埗缃戞牸鑳屾櫙"""
        painter.fillRect(rect, QColor("#F5F5F5"))
        painter.setRenderHint(QPainter.RenderHint.Antialiasing, False)
        grid_size = 30
        pen = QPen(QColor("#E0E0E0"), 0.5)
        painter.setPen(pen)

        left = int(rect.left()) - (int(rect.left()) % grid_size)
        top = int(rect.top()) - (int(rect.top()) % grid_size)

        x = left
        while x < rect.right():
            painter.drawLine(int(x), int(rect.top()), int(x), int(rect.bottom()))
            x += grid_size

        y = top
        while y < rect.bottom():
            painter.drawLine(int(rect.left()), int(y), int(rect.right()), int(y))
            y += grid_size

    # ==================== 鍏叡鏂规硶 ====================

    def auto_layout(self):
        self._scene.auto_layout()
        self._fit_to_content()

    def _fit_to_content(self):
        """鑷€傚簲鏄剧ず鎵€鏈夊崱鐗?""
        items = self._scene.get_all_cards()
        if not items:
            return
        rect = QRectF()
        for item in items:
            rect = rect.united(item.sceneBoundingRect())
        rect.adjust(-50, -50, 50, 50)
        self.fitInView(rect, Qt.AspectRatioMode.KeepAspectRatio)
        self._zoom = self.transform().m11()

    def zoom_in(self):
        if self._zoom >= 3.0:
            return
        self.scale(1.15, 1.15)
        self._zoom = min(self._zoom * 1.15, 3.0)
        self.zoomChanged.emit(self._zoom)

    def zoom_out(self):
        if self._zoom <= 0.2:
            return
        self.scale(1 / 1.15, 1 / 1.15)
        self._zoom = max(self._zoom / 1.15, 0.2)
        self.zoomChanged.emit(self._zoom)

    def zoom_reset(self):
        self.resetTransform()
        self._zoom = 1.0
        self._fit_to_content()
        self.zoomChanged.emit(self._zoom)


