def _to_str_series(x):
    """灏?Series 鎴栨爣閲忓畨鍏ㄨ浆涓哄瓧绗︿覆 Series銆?""
    if isinstance(x, pd.Series):
        return x.astype(str)
    return str(x)


def _concat(*args):
    """CONCAT 鍑芥暟瀹炵幇锛氭嫾鎺ュ涓?Series/鏍囬噺涓哄瓧绗︿覆銆?""
    args = list(args)
    result = args[0]
    if not isinstance(result, pd.Series):
        result = str(result)
    else:
        result = result.astype(str)
    for a in args[1:]:
        if isinstance(a, pd.Series):
            result = result + a.astype(str)
        else:
            result = result + str(a)
    return result


def _text_join(sep, *args):
    """TEXTJOIN 鍑芥暟瀹炵幇銆?""
    result = _to_str_series(args[0])
    for a in args[1:]:
        result = result + str(sep) + _to_str_series(a)
    return result


def _ifs(*args):
    """IFS 鍑芥暟瀹炵幇: IFS(cond1, val1, cond2, val2, ...)"""
    if len(args) < 2 or len(args) % 2 != 0:
        raise ValueError("IFS 闇€瑕佹垚瀵圭殑鏉′欢鍜屽€?)
    result = pd.Series(np.nan, index=args[0].index)
    for i in range(0, len(args), 2):
        cond, val = args[i], args[i + 1]
        # 鍙～鍏呭皻鏈祴鍊肩殑琛?
        mask = cond & result.isna()
        if isinstance(val, pd.Series):
            result = result.where(~mask, val)
        else:
            result = result.where(~mask, val)
    return result


def _isnumber(s):
    """ISNUMBER 鍑芥暟瀹炵幇銆?""
    return s.apply(lambda x: isinstance(x, (int, float)) and not isinstance(x, bool))


def _istext(s):
    """ISTEXT 鍑芥暟瀹炵幇銆?""
    return s.apply(lambda x: isinstance(x, str))


def _isblank(s):
