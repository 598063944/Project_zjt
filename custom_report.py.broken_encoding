    def _export_report(self, rid: str):
        """瀵煎嚭鎶ヨ〃瀹氫箟涓?.crpt 鏂囦欢"""
        report = self._repo.get(rid)
        if not report:
            return
        from PyQt6.QtWidgets import QFileDialog
        path, _ = QFileDialog.getSaveFileName(
            self, "瀵煎嚭鎶ヨ〃瀹氫箟", f"{report.name}.crpt",
            "鎶ヨ〃瀹氫箟鏂囦欢 (*.crpt);;JSON 鏂囦欢 (*.json)"
        )
        if not path:
            return
        try:
            data = report.to_dict()
            data.pop('result_table_name', None)
            data.pop('result_row_count', None)
            data.pop('last_refresh_time', None)
            with open(path, 'w', encoding='utf-8') as f:
                json.dump(data, f, ensure_ascii=False, indent=2)
            _light_msgbox(self, QMessageBox.Icon.Information, "瀵煎嚭鎴愬姛", f"鎶ヨ〃瀹氫箟宸插鍑哄埌:\n{path}")
