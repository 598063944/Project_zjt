    def eventFilter(self, obj, event):
        """Enter 鍙戦€佹秷鎭紝Shift+Enter 鎹㈣"""
        from PyQt6.QtCore import QEvent
        if obj == self._input_edit and event.type() == QEvent.Type.KeyPress:
            if event.key() == Qt.Key.Key_Return or event.key() == Qt.Key.Key_Enter:
                # Shift+Enter 鎹㈣
                if event.modifiers() & Qt.KeyboardModifier.ShiftModifier:
                    return False
                # Enter / Ctrl+Enter 鍙戦€?
                self._on_send()
                return True
        return super().eventFilter(obj, event)

    def _on_send(self):
        user_input = self._input_edit.toPlainText().strip()
        if not user_input:
            return

        # 鏄剧ず鐢ㄦ埛娑堟伅
        self._append_message("馃檵 浣?, user_input)
        self._input_edit.clear()
        self._chat_view.append("鈴?AI 鎬濊€冧腑...")

        from PyQt6.QtCore import QTimer
        QTimer.singleShot(50, lambda: self._do_chat(user_input))

    def _do_chat(self, user_input: str):
        response = self._assistant.chat(user_input, self._sources_info)
        # 绉婚櫎"鎬濊€冧腑"
        cursor = self._chat_view.textCursor()
        cursor.movePosition(cursor.MoveOperation.End)
        cursor.select(cursor.SelectionType.BlockUnderCursor)
        cursor.removeSelectedText()
        cursor.deletePreviousChar()

        # 鏄剧ず AI 鍝嶅簲
        self._append_message("馃 AI", response)

        # 灏濊瘯瑙ｆ瀽 JSON 鍥捐〃瀹氫箟
        self._chart_def = None
        try:
            text = response
            json_str = None
            if '```json' in text:
                json_str = text.split('```json')[1].split('```')[0].strip()
            elif '```' in text:
                json_str = text.split('```')[1].split('```')[0].strip()
            elif '{' in text and '}' in text:
                start = text.index('{')
                end = text.rindex('}') + 1
                json_str = text[start:end]

            if json_str:
                parsed = json.loads(json_str)
                if isinstance(parsed, dict) and 'chart_type' in parsed:
                    self._chart_def = parsed
                    self._add_btn.setEnabled(True)
                    self._append_message("馃挕 鎻愮ず", f"妫€娴嬪埌鍥捐〃瀹氫箟銆寋parsed.get('title', '鏈懡鍚?)}銆嶏紝鐐瑰嚮涓嬫柟鎸夐挳娣诲姞鍒颁华琛ㄧ洏")
                    _ui_output(f"[BI 鎶ヨ〃] AI 杩斿洖浜嗗浘琛ㄥ畾涔? {parsed.get('title', '鏈懡鍚?)}")
        except Exception:
            self._add_btn.setEnabled(False)

    def _append_message(self, role: str, content: str):
        """杩藉姞涓€鏉℃秷鎭埌瀵硅瘽鍘嗗彶"""
        self._chat_history.append({"role": role, "content": content})
        html = f'<p><b style="color:#1890FF">{role}:</b></p><p style="margin:4px 0 12px 12px;white-space:pre-wrap;">{content}</p>'
        self._chat_view.append(html)

    def _on_clear(self):
        self._chat_view.clear()
        self._chat_history.clear()
