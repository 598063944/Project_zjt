# ==================== 涓枃鏍囩偣瑙勮寖鍖?====================

_CJK_PUNCT_MAP = str.maketrans({
    '锛?: '(', '锛?: ')', '锛?: ',', '锛?: ':',
    '鈥?: '"', '鈥?: '"', '鈥?: "'", '鈥?: "'",
    '锛?: '+', '锛?: '-', '脳': '*', '梅': '/',
