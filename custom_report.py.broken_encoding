    """鍚庡彴鍒锋柊绾跨▼"""
    progress = pyqtSignal(str, str, int)  # phase, message, percent
    finished = pyqtSignal(dict)           # result dict

    def __init__(self, worker: ReportRefreshWorker, report: ReportDefinition):
        super().__init__()
        self._worker = worker
        self._report = report

    def run(self):
        result = self._worker.refresh(
            self._report,
            progress_callback=lambda p, m, pc: self.progress.emit(p, m, pc),
        )
        self.finished.emit(result)




class BatchRefreshThread(QThread):
    """鎵归噺鍒锋柊绾跨▼鈥斺€旀渶澶氬悓鏃惰窇3涓姤琛紝鍚庡彴鎵ц涓嶅奖鍝峌I鎿嶄綔銆?

    姣忎釜鎶ヨ〃鍐呴儴涓茶锛欳RM鎷夊彇 -> MySQL鍐欏叆 -> 鎷艰〃
    鎶ヨ〃涔嬮棿锛氭渶澶?涓苟鍙戯紙ThreadPoolExecutor max_workers=3锛?
    姣忎釜worker鐙珛鏁版嵁搴撹繛鎺ワ紝Repo.save鐢↙ock淇濇姢銆?
    """
    report_starting = pyqtSignal(str, str)        # (report_id, name)
    report_progress = pyqtSignal(str, str, str)   # (report_id, phase, message)
    report_done    = pyqtSignal(str, dict)        # (report_id, result)
    all_done       = pyqtSignal(int, int, list)   # (鎴愬姛鏁? 澶辫触鏁? [(name, error)])

    def __init__(self, mysql_config, repo, report_ids, app_config=None):
        super().__init__()
        self._mysql_config = mysql_config
        self._repo = repo
        self._report_ids = list(report_ids)
        self._app_config = app_config or {}
        self._cancelled = False

    def cancel(self):
        self._cancelled = True

    def run(self):
        from concurrent.futures import ThreadPoolExecutor, as_completed
        import threading

        success = 0
        fail = 0
        errors = []
        save_lock = threading.Lock()

        def _refresh_one(rid):
            if self._cancelled:
                return rid, {'success': False, 'error': '宸插彇娑?}

            report = self._repo.get(rid)
            if not report:
                return rid, {'success': False, 'error': '鎶ヨ〃鏈壘鍒?}

            self.report_starting.emit(rid, report.name)

            # 姣忎釜绾跨▼鐙珛鏁版嵁搴撹繛鎺?
            db = ReportDatabase(self._mysql_config)
            fetcher = DataFetcher(config=self._app_config)
            try:
                syncer = SourceTableSyncer(db, fetcher)
                worker = ReportRefreshWorker(db, syncer)

                def _progress(phase, msg, pct):
                    if not self._cancelled:
                        self.report_progress.emit(rid, phase, msg)

                result = worker.full_refresh(report, progress_callback=_progress)

                if result['success']:
                    with save_lock:
                        self._repo.save(report)
            except Exception as e:
                import traceback
                result = {'success': False, 'row_count': 0, 'error': str(e),
                          'traceback': traceback.format_exc(), 'duration': 0}
            finally:
                db.close()

            return rid, result

        try:
            with ThreadPoolExecutor(max_workers=3) as pool:
                futures = {pool.submit(_refresh_one, rid): rid for rid in self._report_ids}
                for future in as_completed(futures):
                    if self._cancelled:
                        break
                    try:
                        rid, result = future.result()
                        self.report_done.emit(rid, result)
                        if result['success']:
                            success += 1
                        else:
                            fail += 1
                            rpt = self._repo.get(rid)
                            name = rpt.name if rpt else rid
                            errors.append((name, result.get('error', '')))
                    except Exception as e:
                        fail += 1
                        errors.append(("\u5f02\u5e38", str(e)))
        finally:
            self.all_done.emit(success, fail, errors)

