        field_name = str(field_name or '').strip()
        if not field_name:
            return ""
        normalized = field_name
        for suffix in ('__r', '__c'):
            if normalized.endswith(suffix):
                normalized = normalized[:-len(suffix)]
        keyword_labels = [
            ('create', '鍒涘缓'),
            ('modified', '淇敼'),
            ('submit', '鎻愪氦'),
            ('owner', '璐熻矗浜?),
            ('account', '瀹㈡埛'),
            ('customer', '瀹㈡埛'),
            ('contact', '鑱旂郴浜?),
            ('mobile', '鎵嬫満'),
            ('phone', '鐢佃瘽'),
            ('address', '鍦板潃'),
            ('amount', '閲戦'),
            ('price', '浠锋牸'),
            ('status', '鐘舵€?),
            ('stage', '闃舵'),
            ('type', '绫诲瀷'),
            ('source', '鏉ユ簮'),
            ('remark', '澶囨敞'),
            ('description', '鎻忚堪'),
            ('date', '鏃ユ湡'),
            ('time', '鏃堕棿'),
        ]
        lower_name = normalized.lower()
        for keyword, label in keyword_labels:
            if keyword in lower_name:
                return label
        if field_name.startswith('field_'):
            return f"鑷畾涔夊瓧娈碉紙{field_name}锛?
        return field_name


