def _tokenize_excel_formula(expr: str) -> list[tuple[str, str]]:
    """灏?Excel 鍏紡鎷嗗垎涓?token 鍒楄〃銆?

    姣忛」涓?(type, value)锛宼ype 鍖呮嫭:
      'func'   - 鍑芥暟鍚嶏紙鍚庤窡 '('锛?
      'lparen' - '('
      'rparen' - ')'
      'comma'  - ','
      'col'    - 鍒楀紩鐢紙浼氳鏇挎崲锛?
      'literal' - 瀛楃涓插瓧闈㈤噺 'xxx' 鎴?"xxx"
      'number' - 鏁板瓧
      'op'     - 杩愮畻绗?+ - * / > < = & 绛?
      'ident'  - 鍏朵粬鏍囪瘑绗?
    """
    tokens = []
    i = 0
    n = len(expr)

    while i < n:
        ch = expr[i]

        # 绌虹櫧
        if ch.isspace():
            i += 1
            continue

        # 瀛楃涓插瓧闈㈤噺
        if ch in ("'", '"'):
            quote = ch
            j = i + 1
            while j < n and expr[j] != quote:
                if expr[j] == '\\':
                    j += 1
                j += 1
            tokens.append(('literal', expr[i:j + 1]))
            i = j + 1
            continue

        # 鏁板瓧
        if ch.isdigit() or (ch == '.' and i + 1 < n and expr[i + 1].isdigit()):
            j = i
            while j < n and (expr[j].isdigit() or expr[j] == '.'):
                j += 1
            tokens.append(('number', expr[i:j]))
            i = j
            continue

        # 鎷彿 / 閫楀彿
        if ch == '(':
            # 鍓嶄竴涓?token 鏄爣璇嗙 鈫?鍑芥暟鍚?
            if tokens and tokens[-1][0] == 'ident':
                prev_val = tokens.pop()[1]
                if prev_val.upper() in _EXCEL_FUNC_REGISTRY:
                    tokens.append(('func', prev_val.upper()))
                else:
                    # 涓嶆槸娉ㄥ唽鐨勫嚱鏁帮紝杩樺師涓?ident
                    tokens.append(('ident', prev_val))
            tokens.append(('lparen', '('))
            i += 1
            continue
        if ch == ')':
            tokens.append(('rparen', ')'))
            i += 1
            continue
        if ch == ',':
            tokens.append(('comma', ','))
            i += 1
            continue

        # 杩愮畻绗?
        if ch in '+-*/><=&|^%':
            if i + 1 < n and expr[i:i + 2] in ('>=', '<=', '!=', '=='):
                tokens.append(('op', expr[i:i + 2]))
                i += 2
            else:
                tokens.append(('op', ch))
                i += 1
            continue

        # 鏍囪瘑绗︼紙鍒楀悕銆佸嚱鏁板悕銆佸叧閿瓧锛?
        j = i
        while j < n and not expr[j].isspace() and expr[j] not in '(),\'"+-*/><=&|^%':
            j += 1
        ident = expr[i:j]
        # 濡傛灉绱ф帴鐫€鏄?(, 浼氫綔涓哄嚱鏁板悕澶勭悊
        tokens.append(('ident', ident))
        i = j

    return tokens


def _convert_tokens_to_python(tokens: list[tuple[str, str]],
                               col_map: dict[str, str]) -> str:
    """灏?Excel token 鍒楄〃杞崲涓?Python 琛ㄨ揪寮忋€?

    Args:
        tokens: token 鍒楄〃
        col_map: {鍘熷鍒楀悕: 瀹夊叏 DF 鍒楀悕} 鏄犲皠锛堝疄闄呭凡琚浛鎹級

    Returns:
        Python 琛ㄨ揪寮忓瓧绗︿覆
    """
    parts = []
    for ttype, tval in tokens:
        if ttype == 'func':
            # Excel 鍑芥暟 鈫?Python 鍑芥暟寮曠敤锛堥€氳繃 _EF 鍛藉悕绌洪棿璁块棶锛?
            parts.append(f"_EF['{tval}']")
        elif ttype == 'lparen':
            parts.append('(')
        elif ttype == 'rparen':
            parts.append(')')
        elif ttype == 'comma':
            parts.append(',')
        elif ttype == 'op':
            parts.append(tval)
        elif ttype == 'number':
            parts.append(tval)
        elif ttype == 'literal':
            parts.append(tval)
        elif ttype == 'ident':
            # 鏍囪瘑绗﹀彲鑳芥槸鍒楀悕 鈫?鏇挎崲涓?_df[...] 璁块棶
            # 鍏堟鏌ユ槸鍚﹀尮閰嶄换涓€鍒楀悕
            if tval in col_map:
                parts.append(f"_df['{tval}']")
            else:
                parts.append(tval)
        else:
            parts.append(tval)

    return ' '.join(parts)


def _eval_formula(expr: str, df: pd.DataFrame) -> pd.Series:
    """瀵?DataFrame 姹傚€煎崟涓?Excel 鍏紡銆?

    绠楁硶:
    1. 瑙ｆ瀽 token
    2. 璇嗗埆鍒楀悕锛堥€氳繃 _find_col_refs_in_tokens 杈呭姪鍖归厤 df 鐨勫垪锛?
    3. 杞崲鎴?Python 琛ㄨ揪寮?
    4. 鍦ㄥ彈鎺у懡鍚嶇┖闂翠腑 eval

    Args:
        expr: 瑙勮寖鍖栧悗鐨?Excel 鍏紡锛堝凡鍘荤瓑鍙枫€佸凡鏇挎崲涓枃鏍囩偣锛?
        df: 鏁版嵁 DataFrame

    Returns:
        璁＄畻缁撴灉 Series
    """
    # 鏋勫缓鍒楀悕鍖归厤琛?
    df_cols = df.columns.tolist()
    col_map = {c: c for c in df_cols}  # 淇濇寔鍘熷鍒楀悕涓嶅彉

    # 灏濊瘯绠€鍗曟儏鍐碉細绾畻鏈〃杈惧紡 鈫?鐩存帴鐢?df.eval
    if not _has_excel_func(expr):
        safe_expr, safe_map, _ = _replace_column_refs(expr, df_cols)
        rename_map = {v: k for k, v in safe_map.items()}
        temp_df = df.rename(columns=rename_map)
        try:
            return temp_df.eval(safe_expr)
        except Exception:
            pass

    # 澶嶆潅鎯呭喌锛氭湁 Excel 鍑芥暟 鈫?tokenize + convert
    tokens = _tokenize_excel_formula(expr)

    # 灏?tokens 涓湭璇嗗埆鐨?ident 灏濊瘯鍖归厤鍒楀悕
    col_set = set(df_cols)
    for idx, (ttype, tval) in enumerate(tokens):
        if ttype == 'ident' and tval in col_set:
            tokens[idx] = ('col', tval)
        elif ttype == 'ident':
            # 灏濊瘯妯＄硦鍖归厤
            for col in df_cols:
                if col in tval or tval in col:
                    # 涓嶈嚜鍔ㄦ浛鎹紝淇濇寔鍘熸牱锛堝彲鑳芥槸鍙橀噺鍚嶏級
                    pass

    # 鏋勫缓 Python 琛ㄨ揪寮?
    py_expr = _build_python_expr_from_tokens(tokens, df_cols)

    # 鏋勫缓鍙楁帶鐨?eval 鍛藉悕绌洪棿
    namespace = {
        '_df': df,
        '_EF': _build_func_wrappers(),
        'np': np,
        'pd': pd,
    }

    try:
        result = eval(py_expr, {"__builtins__": {}}, namespace)
        return _ensure_series(result, df.index)
    except Exception as e:
        raise ValueError(f"鍏紡姹傚€煎け璐? {e}")


def _has_excel_func(expr: str) -> bool:
    """妫€鏌ヨ〃杈惧紡鏄惁鍖呭惈 Excel 鍑芥暟璋冪敤銆?""
    for func_name in _EXCEL_FUNC_REGISTRY:
        pattern = r'\b' + func_name + r'\s*\('
        if re.search(pattern, expr, re.IGNORECASE):
            return True
    return False


def _build_func_wrappers() -> dict:
    """鏋勫缓鍑芥暟鍖呰鍣細浠庢敞鍐岃〃涓彁鍙栫函鍑芥暟閮ㄥ垎銆?

    杩斿洖 {FUNC_NAME: callable}锛屼絾鍖呰浜嗗弬鏁板鐞嗛€昏緫銆?
    """
    wrappers = {}
    for name, (func, min_args, max_args) in _EXCEL_FUNC_REGISTRY.items():
        wrappers[name] = func
    return wrappers


def _build_python_expr_from_tokens(tokens: list[tuple[str, str]],
                                    df_cols: list[str]) -> str:
    """灏?token 鍒楄〃杞崲涓哄彲鎵ц鐨?Python 琛ㄨ揪寮忓瓧绗︿覆銆?

    杞崲瑙勫垯:
    - func(token)  鈫?_EF['FUNC_NAME'](
    - col(token)   鈫?_df['col_name']
    - ident(token) 鈫?token锛堝彲鑳芥槸 True/False/None锛?
    - 鍏朵綑淇濇寔鍘熸牱
    """
    parts = []
    col_set = set(df_cols)

    for ttype, tval in tokens:
        if ttype == 'func':
            # 鍑芥暟寮曠敤锛屼笉杩藉姞 '(' 鈥?鐢辩揣璺熺殑 lparen 澶勭悊
            parts.append(f"_EF['{tval}']")
        elif ttype == 'lparen':
            parts.append('(')
        elif ttype == 'rparen':
            parts.append(')')
        elif ttype == 'comma':
            parts.append(',')
        elif ttype == 'col':
            parts.append(f"_df['{tval}']")
        elif ttype == 'ident':
            upper = tval.upper()
            if upper in ('TRUE', 'FALSE', 'NONE'):
                parts.append(upper == 'TRUE' and 'True' or (upper == 'FALSE' and 'False' or 'None'))
            elif _is_number(tval):
                parts.append(tval)
            elif tval in col_set:
                parts.append(f"_df['{tval}']")
            else:
                parts.append(tval)
        elif ttype == 'number':
            parts.append(tval)
        elif ttype == 'literal':
            parts.append(tval)
        elif ttype == 'op':
            parts.append(' ' + tval + ' ')
        else:
            parts.append(tval)

    return ''.join(parts)


def _is_number(s: str) -> bool:
    try:
        float(s)
        return True
    except ValueError:
        return False


def _ensure_series(result, index) -> pd.Series:
    """纭繚缁撴灉鏄?pandas Series锛堟爣閲忓€煎箍鎾负 Series锛夈€?""
    if isinstance(result, pd.Series):
        return result
    if isinstance(result, pd.DataFrame):
        return result.iloc[:, 0]
    if np.isscalar(result):
        return pd.Series(result, index=index)
    return pd.Series(result, index=index)


