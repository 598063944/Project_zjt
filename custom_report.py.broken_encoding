    # 绮剧‘鍖归厤
    if field_name in _COMMON_FIELD_LABELS:
        return _COMMON_FIELD_LABELS[field_name]

    # 鍘绘帀鍚庣紑
    normalized = field_name
    for suffix in ('__r', '__c'):
        if normalized.endswith(suffix):
            normalized = normalized[:-len(suffix)]

    # 鍏抽敭璇嶅尮閰?
    keyword_map = [
        ('create', '鍒涘缓'), ('modified', '淇敼'), ('submit', '鎻愪氦'),
        ('owner', '璐熻矗浜?), ('account', '瀹㈡埛'), ('customer', '瀹㈡埛'),
        ('contact', '鑱旂郴浜?), ('mobile', '鎵嬫満'), ('phone', '鐢佃瘽'),
        ('address', '鍦板潃'), ('amount', '閲戦'), ('price', '浠锋牸'),
        ('quantity', '鏁伴噺'), ('status', '鐘舵€?), ('stage', '闃舵'),
        ('source', '鏉ユ簮'), ('remark', '澶囨敞'), ('description', '鎻忚堪'),
        ('date', '鏃ユ湡'), ('time', '鏃堕棿'), ('type', '绫诲瀷'), ('name', '鍚嶇О'),
        ('code', '缂栫爜'), ('number', '缂栧彿'), ('delivery', '鍙戣揣'),
        ('product', '浜у搧'), ('order', '璁㈠崟'), ('project', '椤圭洰'),
    ]
    lower = normalized.lower()
    for kw, label in keyword_map:
        if kw in lower:
            return label

    if field_name.startswith('field_'):
        return f"鑷畾涔夊瓧娈?{field_name})"

    return field_name


def build_field_labels(field_names: list[str],
                       object_labels: dict = None,
                       custom_config: dict = None) -> dict[str, str]:
    """
    涓轰竴缁勫瓧娈靛悕鏋勫缓涓枃鏍囩鏄犲皠

    Args:
        field_names: API 瀛楁鍚嶅垪琛?
        object_labels: 瀵硅薄鐗瑰畾鐨勬爣绛炬槧灏?{(key: label)}
        custom_config: 鐢ㄦ埛鑷畾涔夌殑鏍囩鏄犲皠

    Returns:
        {field_name: display_label}
    """
    result = {}
    label_usage = {}  # 妫€娴嬮噸澶嶆爣绛?

    for key in field_names:
        # 浼樺厛绾? 鑷畾涔?> 瀵硅薄鐗瑰畾 > 閫氱敤鐚滄祴
        if custom_config and key in custom_config:
            label = custom_config[key]
        elif object_labels and key in object_labels:
            label = object_labels[key]
        else:
            label = guess_field_label(key)

        # 鍘婚噸澶勭悊
        if label in label_usage:
            label_usage[label] += 1
            result[key] = f"{label}({key})"
        else:
            label_usage[label] = 1
            result[key] = label

    return result


