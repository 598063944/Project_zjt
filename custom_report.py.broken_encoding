        new_sub_action = menu.addAction("馃搧 鏂板缓瀛愭枃浠跺す")
        new_sub_action.triggered.connect(lambda: self._on_new_folder(item))

        if item:
            folder_path = item.data(0, Qt.ItemDataRole.UserRole)

            new_report_action = menu.addAction("馃搳 鍦ㄦ鏂板缓鎶ヨ〃")
