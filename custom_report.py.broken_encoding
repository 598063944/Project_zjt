def _translate_weeknum(expr: str) -> str:
    """灏?Excel WEEKNUM 缈昏瘧涓?MySQL WEEK銆?

    WEEKNUM(date)       鈫?WEEK(date, 3)   (榛樿 return_type=2: 鍛ㄤ竴寮€濮嬶紝鍚?1/1 鐨勫懆涓虹 1 鍛?
    WEEKNUM(date, 1)    鈫?WEEK(date, 2)   (鍛ㄦ棩寮€濮?
    WEEKNUM(date, 2)    鈫?WEEK(date, 3)   (鍛ㄤ竴寮€濮?
    """
    def _replace(m):
        args_str = m.group(1).strip()
        if ',' in args_str:
            # 鏈夌浜屼釜鍙傛暟锛氭壘鍒扮涓€涓笉鍦ㄦ嫭鍙峰唴鐨勯€楀彿
            depth = 0
            split_pos = -1
            for i, ch in enumerate(args_str):
                if ch == '(':
                    depth += 1
                elif ch == ')':
                    depth -= 1
                elif ch == ',' and depth == 0:
                    split_pos = i
                    break
            if split_pos > 0:
                date_part = args_str[:split_pos].strip()
                mode_part = args_str[split_pos + 1:].strip()
                if mode_part == '1':
                    return f'WEEK({date_part}, 2)'
                else:
                    return f'WEEK({date_part}, 3)'
        return f'WEEK({args_str}, 3)'

    return re.sub(r'WEEKNUM\s*\(', '__WEEKNUM_START__(', expr, flags=re.IGNORECASE)


# Excel 鈫?MySQL 鏃ユ湡鏍煎紡杞崲鏄犲皠锛堜笉鍚?mm锛屽洜鍏跺惈涔夊彇鍐充簬涓婁笅鏂囷級
_EXCEL_TO_MYSQL_DATE_FORMAT = [
    ('yyyy', '%Y'), ('yy', '%y'),
    ('MMMM', '%M'), ('MMM', '%b'), ('MM', '%m'),
    ('dddd', '%W'), ('ddd', '%a'), ('dd', '%d'),
    ('HH', '%H'), ('hh', '%h'),
    ('ss', '%S'),
    ('AM/PM', '%p'), ('A/P', '%p'),
]


def _excel_date_format_to_mysql(excel_fmt: str) -> str:
    """灏?Excel 鏃ユ湡鏍煎紡瀛楃涓茶浆鎹负 MySQL DATE_FORMAT 鏍煎紡瀛楃涓层€?

    Excel 涓?mm 鍚箟鍙栧喅浜庝笂涓嬫枃锛?
      - 涓?H/h/s 鍚屾椂鍑虹幇鏃?鈫?鍒嗛挓 鈫?MySQL %i
      - 鍚﹀垯 鈫?鏈堜唤 鈫?MySQL %m
    """
    result = excel_fmt
    for excel_pat, mysql_pat in _EXCEL_TO_MYSQL_DATE_FORMAT:
        result = result.replace(excel_pat, mysql_pat)

    # 鍦ㄤ笂涓嬫枃鏁忔劅鐨勬槧灏勪箣鍓嶏紝鍏堝畬鎴?MM 鈫?%m锛屽啀鏍规嵁鏍煎紡涓槸鍚﹀惈鏃堕棿鎴愬垎鏉ュ喅瀹?mm 鐨勫惈涔?
    has_time_context = bool(re.search(r'[Hhs]', excel_fmt))
    if has_time_context:
        result = result.replace('mm', '%i')   # 鍒嗛挓
    else:
        result = result.replace('mm', '%m')   # 鏈堜唤锛堢函鏃ユ湡鏍煎紡锛?
    return result


def _has_date_format_patterns(fmt: str) -> bool:
    """鍒ゆ柇鏍煎紡瀛楃涓叉槸鍚﹀寘鍚棩鏈熸牸寮忔ā寮忥紙y, M, d, H, h, s 绛夛級銆?""
    date_indicators = {'y', 'M', 'd', 'H', 'h', 's', 'A', 'P', '涓婂崍', '涓嬪崍'}
    return any(c in fmt for c in date_indicators)


def _split_func_args(args_str: str, count: int) -> list[str]:
    """鎸夐《灞傞€楀彿鍒嗗壊鍑芥暟鍙傛暟锛屽拷鐣ュ祵濂楁嫭鍙峰唴鐨勯€楀彿銆?""
    parts = []
    depth = 0
    start = 0
    for i, ch in enumerate(args_str):
        if ch == '(':
            depth += 1
        elif ch == ')':
            depth -= 1
        elif ch == ',' and depth == 0:
            parts.append(args_str[start:i].strip())
            start = i + 1
            if len(parts) >= count - 1:
                break
    parts.append(args_str[start:].strip())
    return parts


def _translate_date_to_sql(expr: str) -> str:
    """灏?Excel DATE(year, month, day) 缈昏瘧涓?MySQL STR_TO_DATE 琛ㄨ揪寮忋€?""
    def _replace(m):
        args_str = m.group(1).strip()
        parts = _split_func_args(args_str, 3)
        if len(parts) < 3:
            return m.group(0)  # 鏃犳硶瑙ｆ瀽锛屼繚鐣欏師鏍?
        y, m_name, d = parts[0], parts[1], parts[2]
        return (
            f"STR_TO_DATE(CONCAT({y}, '-', LPAD({m_name}, 2, '0'), '-', "
            f"LPAD({d}, 2, '0')), '%Y-%m-%d')"
        )

    # 浣跨敤鎵嬪姩瀛楃绾у尮閰嶆潵姝ｇ‘澶勭悊宓屽鎷彿
    result = []
    i = 0
    n = len(expr)
    while i < n:
        # 鏌ユ壘 DATE(
        if i + 4 < n and expr[i:i+4].upper() == 'DATE':
            j = i + 4
            # 璺宠繃绌烘牸
            while j < n and expr[j] == ' ':
                j += 1
            if j < n and expr[j] == '(':
                # 鎵惧埌鍖归厤鐨勫彸鎷彿
                depth = 1
                k = j + 1
                while k < n and depth > 0:
                    if expr[k] == '(':
                        depth += 1
                    elif expr[k] == ')':
                        depth -= 1
                    k += 1
                if depth == 0:
                    args_str = expr[j+1:k-1].strip()
                    parts = _split_func_args(args_str, 3)
                    if len(parts) >= 3:
                        y, m_name, d = parts[0], parts[1], parts[2]
                        result.append(
                            f"STR_TO_DATE(CONCAT({y}, '-', LPAD({m_name}, 2, '0'), '-', "
                            f"LPAD({d}, 2, '0')), '%Y-%m-%d')"
                        )
                        i = k
                        continue
            # 鏈尮閰嶅埌瀹屾暣鐨?DATE(...)锛屼繚鐣欏師瀛楃
            result.append(expr[i])
            i += 1
        else:
            result.append(expr[i])
            i += 1

    return ''.join(result)


def _translate_text_to_sql(expr: str) -> str:
    """灏?Excel TEXT(value, format_string) 缈昏瘧涓?MySQL DATE_FORMAT 鎴?CAST銆?

    瀵逛簬鏃ユ湡鏍煎紡 鈫?DATE_FORMAT(value, mysql_format)
    瀵逛簬鏁板€兼牸寮?鈫?CAST(value AS CHAR)
    """
    result = []
    i = 0
    n = len(expr)
    while i < n:
        # 鏌ユ壘 TEXT(
        if i + 4 < n and expr[i:i+4].upper() == 'TEXT':
            j = i + 4
            while j < n and expr[j] == ' ':
                j += 1
            if j < n and expr[j] == '(':
                depth = 1
                k = j + 1
                while k < n and depth > 0:
                    if expr[k] == '(':
                        depth += 1
                    elif expr[k] == ')':
                        depth -= 1
                    k += 1
                if depth == 0:
                    args_str = expr[j+1:k-1].strip()
                    parts = _split_func_args(args_str, 2)
                    if len(parts) >= 2:
                        value_expr = parts[0]
                        fmt_str = parts[1].strip()

                        # 鍘婚櫎澶栧眰寮曞彿
                        if (fmt_str.startswith('"') and fmt_str.endswith('"')) or \
                           (fmt_str.startswith("'") and fmt_str.endswith("'")):
                            fmt_str = fmt_str[1:-1]

                        if _has_date_format_patterns(fmt_str):
                            mysql_fmt = _excel_date_format_to_mysql(fmt_str)
                            result.append(
                                f"DATE_FORMAT({value_expr}, '{mysql_fmt}')"
                            )
                        else:
                            result.append(f"CAST({value_expr} AS CHAR)")
                        i = k
                        continue
            result.append(expr[i])
            i += 1
        else:
            result.append(expr[i])
            i += 1

    return ''.join(result)


def translate_formula_to_sql(expr: str, column_names: list[str],
                             table_alias: str = '_base') -> str | None:
    """灏?Excel 鍏紡琛ㄨ揪寮忕炕璇戜负 MySQL SQL 琛ㄨ揪寮忋€?

    鍒楀紩鐢ㄦ浛鎹负 `{alias}`.`鍒楀悕` 褰㈠紡锛孍xcel 鍑芥暟鏄犲皠涓?MySQL 绛変环鍑芥暟銆?
    鑻ュ叕寮忓寘鍚?MySQL 涓嶆敮鎸佺殑鍑芥暟锛岃繑鍥?None锛堢敱璋冪敤鏂归€€鍥?pandas 璁＄畻锛夈€?

    Args:
        expr: 鍘熷鍏紡琛ㄨ揪寮忥紙濡?'=鍗曚环*鏁伴噺' 鎴?'=IF(閲戦>1000, "澶ч", "灏忛")'锛?
        column_names: 鍐呭眰鏌ヨ鐨勫垪鍚嶅垪琛紙鐢ㄤ簬鍖归厤骞舵浛鎹㈠垪寮曠敤锛?
        table_alias: 瀛愭煡璇㈠埆鍚嶏紙榛樿 '_base'锛?

    Returns:
        MySQL SQL 琛ㄨ揪寮忓瓧绗︿覆锛屾垨 None锛堣〃绀烘棤娉曠炕璇戯級
    """
    expr = _normalize_expr(expr)
    if not expr.strip():
        return 'NULL'

    # 妫€鏌ュ叕寮忔槸鍚﹁鎴柇锛堝寘鍚渷鐣ュ彿绛夊紓甯?Unicode 瀛楃锛?
    _TRUNCATION_INDICATORS = {'鈥?, '鈥?, '锛?}  # 鈥? 鈥? 锛?
    for ch in _TRUNCATION_INDICATORS:
        if ch in expr:
            logger.warning(f"[FormulaSQL] 鍏紡鍖呭惈鎴柇鏍囪 U+{ord(ch):04X}锛岄€€鍥?pandas 璁＄畻")
            return None

    # 妫€鏌ユ嫭鍙锋槸鍚︽垚瀵癸紙闃叉鎴柇鎴栨崯姣佺殑鍏紡鐢熸垚鏃犳晥 SQL锛?
    if expr.count('(') != expr.count(')'):
        logger.warning(f"[FormulaSQL] 鍏紡鎷彿涓嶅尮閰?(宸?{expr.count('(')} 鍙?{expr.count(')')})锛岄€€鍥?pandas 璁＄畻")
        return None

    # 妫€鏌ユ槸鍚﹀寘鍚笉鍙炕璇戠殑 Excel 鍑芥暟
    for func in _UNTRANSLATABLE_FUNCS:
        if re.search(r'\b' + func + r'\s*\(', expr, re.IGNORECASE):
            logger.info(f"[FormulaSQL] 鍏紡鍖呭惈涓嶆敮鎸佺殑鍑芥暟 '{func}'锛岄€€鍥?pandas 璁＄畻")
            return None

    # 鍏堝鐞嗗瓧绗︿覆瀛楅潰閲忥細淇濇姢璧锋潵閬垮厤鍒楀悕璇尮閰?
    literals = {}

    def _save_literal(m):
        key = f'\x00L{len(literals)}\x00'
        literals[key] = m.group(0)
        return key

    expr = re.sub(r"'[^']*'", _save_literal, expr)
    expr = re.sub(r'"[^"]*"', _save_literal, expr)

    # 鐗规畩澶勭悊 WEEKNUM 鈫?MySQL WEEK
    expr = _translate_weeknum(expr)
    # 杩樺師 WEEKNUM 鍗犱綅绗︼紙_translate_weeknum 鏇挎崲浜嗗嚱鏁板悕寮€澶达紝杩欓噷琛ュ叏鍙傛暟澶勭悊锛?
    # 绠€鍖栧鐞嗭細鐩存帴鍖归厤瀹屾暣鐨?WEEKNUM(...) 璋冪敤
    if '__WEEKNUM_START__' in expr:
        expr = _finish_weeknum_translation(expr)

    # 鎸夊垪鍚嶉暱搴﹂檷搴忔浛鎹㈠垪寮曠敤锛堥伩鍏嶇煭鍒楀悕閿欒鍖归厤闀垮垪鍚嶇殑涓€閮ㄥ垎锛?
    sorted_cols = sorted(column_names, key=len, reverse=True)
    for col in sorted_cols:
        if col in expr:
            quoted = f"`{col.replace('`', '``')}`"
            expr = expr.replace(col, f"{table_alias}.{quoted}")

    # 鎭㈠瀛楅潰閲?
    for key, val in literals.items():
        expr = expr.replace(key, val)

    # 鐗规畩澶勭悊 DATE 鈫?MySQL STR_TO_DATE
    expr = _translate_date_to_sql(expr)
    # 鐗规畩澶勭悊 TEXT 鈫?MySQL DATE_FORMAT / CAST
    expr = _translate_text_to_sql(expr)

    # 缈昏瘧 Excel 鍑芥暟 鈫?MySQL 鍑芥暟
    expr = _translate_functions(expr)

    # 缈昏瘧鍚庡啀娆℃鏌ユ嫭鍙锋槸鍚︽垚瀵癸紙闃叉缈昏瘧杩囩▼寮曞叆闂锛?
    if expr.count('(') != expr.count(')'):
        logger.warning(f"[FormulaSQL] 缈昏瘧鍚庢嫭鍙蜂笉鍖归厤 (宸?{expr.count('(')} 鍙?{expr.count(')')})锛岄€€鍥?pandas 璁＄畻")
        return None

    return expr


def _finish_weeknum_translation(expr: str) -> str:
    """瀹屾垚 WEEKNUM 鈫?WEEK 鐨勭炕璇戯紙澶勭悊鎷彿鍐呯殑鍙傛暟锛夈€?""
    def _replace_full(m):
        args_str = m.group(1).strip()
        if ',' in args_str:
            depth = 0
            split_pos = -1
            for i, ch in enumerate(args_str):
                if ch == '(':
                    depth += 1
                elif ch == ')':
                    depth -= 1
                elif ch == ',' and depth == 0:
                    split_pos = i
                    break
            if split_pos > 0:
                date_part = args_str[:split_pos].strip()
                mode_part = args_str[split_pos + 1:].strip()
                if mode_part == '1':
                    return f'WEEK({date_part}, 2)'
                else:
                    return f'WEEK({date_part}, 3)'
        return f'WEEK({args_str}, 3)'

    return re.sub(r'__WEEKNUM_START__\s*\(([^()]*(?:\([^()]*\)[^()]*)*)\)',
                  _replace_full, expr)


def _translate_functions(expr: str) -> str:
    """灏嗚〃杈惧紡涓殑 Excel 鍑芥暟鍚嶆浛鎹负 MySQL 绛変环鍑芥暟鍚嶃€?""
    for excel_func, mysql_func in _EXCEL_TO_MYSQL_FUNC.items():
        pattern = r'\b' + excel_func + r'\s*\('
        if re.search(pattern, expr, re.IGNORECASE):

            def _replace(m, mf=mysql_func):
                return mf + m.group(0)[len(excel_func):]

            expr = re.sub(pattern, _replace, expr, flags=re.IGNORECASE)
    return expr


